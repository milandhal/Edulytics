NODE_ENV=production
PORT=4000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edulytics?schema=public"

JWT_SECRET="replace-with-a-strong-random-secret-at-least-16-chars"
ACCESS_TOKEN_TTL="8h"
REFRESH_TOKEN_TTL_DAYS="7"

COOKIE_SECURE=true
COOKIE_SAME_SITE="none"
CLIENT_ORIGIN="https://your-frontend-domain.example"

SEED_ADMIN_NAME="Edulytics Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeThisBeforeSeeding123!"

